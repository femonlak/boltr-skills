{
  "name": "boltr-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for BOLTR Tasks - manage tasks, lists, goals, focus sessions, and sprints via AI agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/bundle.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@supabase/supabase-js": "^2.49.4",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "esbuild": "^0.27.3",
    "typescript": "^5.8.3"
  }
}
